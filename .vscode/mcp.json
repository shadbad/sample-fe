{
  // For more information, visit: https://angular.dev/ai/mcp
  "servers": {
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
    },
    "filesystem": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--mount",
        "type=bind,src=/Users/sina/personal/projects/sample/sample-be,dst=/projects/backend,readonly",
        "mcp/filesystem:1.0.2",
        "/projects/backend"
      ]
    }
  }
}
